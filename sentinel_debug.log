# tests/test_integration.py
import os
import tempfile
import pytest
from project_manager.database import ProjectDatabase, 
DatabaseError
from project_manager.models import Project


def test_complete_workflow():
    """Test complete project management workflow."""
    with tempfile.NamedTemporaryFile(suffix=".db", delete=False)
as tmp_file:
        db_path = tmp_file.name
    
    try:
        db = ProjectDatabase(db_path)
        
        # 1. Add projects
        id1 = db.add_project(
            github_url="https://github.com/user/repo1",
            access_token="token1"
        )
        id2 = db.add_project(
            github_url="https://github.com/user/repo2",
            access_token="token2"
        )
        
        assert id1 > 0
        assert id2 > 0
        
        # 2. Retrieve all projects
        projects = db.get_projects()
        assert len(projects) == 2
        
        # 3. Retrieve specific project
        project = db.get_project_by_id(id1)
        assert project is not None
        assert project.id == id1
        assert project.github_url == 
"https://github.com/user/repo1"
        
        # 4. Update project
        updated = db.update_project(id1, 
"https://github.com/user/new-repo", "new-token")
        assert updated is True
        
        # 5. Verify update
        updated_project = db.get_project_by_id(id1)
        assert updated_project.github_url == 
"https://github.com/user/new-repo"
        assert updated_project.access_token == "new-token"
        
        # 6. Delete project
        deleted = db.delete_project(id2)
        assert deleted is True
        
        # 7. Verify deletion
        remaining_projects = db.get_projects()
        assert len(remaining_projects) == 1
        assert remaining_projects[0].id == id1
        
    finally:
        if os.path.exists(db_path):
            os.unlink(db_path)


def test_database_operations_with_error_handling():
    """Test database operations with proper error handling."""
    with tempfile.NamedTemporaryFile(suffix=".db", delete=False)
as tmp_file:
        db_path = tmp_file.name
    
    try:
        db = ProjectDatabase(db_path)
        
        # Test update non-existent project
        updated = db.update_project(999, 
"https://github.com/user/repo", "token")
        assert updated is False  # Should return False for 
non-existent project
        
        # Test delete non-existent project
        deleted = db.delete_project(999)
        assert deleted is False  # Should return False for 
non-existent project
        
        # Test adding project with empty fields (should raise 
ValueError from model)
        with pytest.raises(ValueError):
            Project(1, "", "token")
            
        with pytest.raises(ValueError):
            Project(1, "https://github.com/repo", "")
            
    finally:
        if os.path.exists(db_path):
            os.unlink(db_path)
