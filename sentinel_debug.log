        db = ProjectDatabase(db_path)
        with patch('sqlite3.connect') as mock_connect:
            mock_connect.side_effect = sqlite3.Error("Operation 
failed")
            with pytest.raises(DatabaseError):
                db.add_project("https://github.com/test/repo", 
"token")
                
    finally:
        if os.path.exists(db_path):
            os.unlink(db_path)


def test_database_idempotent_table_creation():
    """Test that table creation is idempotent."""
    with tempfile.NamedTemporaryFile(suffix=".db", delete=False)
as tmp_file:
        db_path = tmp_file.name
    
    try:
        # Initialize database twice
        db1 = ProjectDatabase(db_path)
        db2 = ProjectDatabase(db_path)
        
        # Both should work without error
        assert db1 is not None
        assert db2 is not None
        
        # Verify table exists
        with sqlite3.connect(db_path) as conn:
            cursor = conn.execute("SELECT name FROM 
sqlite_master WHERE type='table' AND name='projects'")
            result = cursor.fetchone()
            assert result is not None
            assert result[0] == "projects"
        
    finally:
        if os.path.exists(db_path):
            os.unlink(db_path)


def test_database_schema_validation():
    """Test that database schema matches requirements."""
    with tempfile.NamedTemporaryFile(suffix=".db", delete=False)
as tmp_file:
        db_path = tmp_file.name
    
    try:
        db = ProjectDatabase(db_path)
        
        # Add a test project
        project_id = db.add_project(
            github_url="https://github.com/test/repo",
            access_token="test-token-123"
        )
        
        # Retrieve and validate project
        project = db.get_project_by_id(project_id)
        assert project is not None
        assert project.id == project_id
        assert project.github_url == 
"https://github.com/test/repo"
        assert project.access_token == "test-token-123"
        
        # Test update functionality
        updated = db.update_project(project_id, 
"https://github.com/test/new-repo", "new-token-456")
        assert updated is True
        
        # Verify update
        updated_project = db.get_project_by_id(project_id)
        assert updated_project.github_url == 
"https://github.com/test/new-repo"
        assert updated_project.access_token == "new-token-456"
        
        # Test delete functionality
        deleted = db.delete_project(project_id)
        assert deleted is True
        
        # Verify deletion
        deleted_project = db.get_project_by_id(project_id)
        assert deleted_project is None
        
    finally:
        if os.path.exists(db_path):
            os.unlink(db_path)


def test_project_model_validation():
    """Test that Project model validation works correctly."""
    # Test valid project
    project = Project(1, "https://github.com/test/repo", 
"token")
    assert project.id == 1
    assert project.github_url == "https://github.com/test/repo"
    assert project.access_token == "token"
    
    # Test invalid projects
    with pytest.raises(ValueError, match="github_url cannot be 
empty"):
        Project(1, "", "token")
    
    with pytest.raises(ValueError, match="access_token cannot be
empty"):
        Project(1, "https://github.com/test/repo", "")
