# Project Configuration
REPO_URL=https://github.com
AGENT_MOCK_MODE=false

# LLM Configuration (xAI / OpenAI Compatible)
# Used by Planner and Coder for speed/efficiency
FAST_MODEL=grok-beta
FAST_KEY=your_xai_key_here
FAST_URL=https://x.ai

# Used for complex logic (if implemented)
REASONING_MODEL=grok-beta
REASONING_KEY=your_xai_key_here
REASONING_URL=https://x.ai

# Fallback Key used by LiteLLM/Aider
XAI_KEY=your_xai_key_here

# GitHub Integration
GITHUB_TOKEN=your_personal_access_token_here

# Hardware/Env specific
# Path to cert bundle if using corporate proxies
SSL_CERT_FILE=/opt/homebrew/lib/python3.14/site-packages/certifi/cacert.pem
