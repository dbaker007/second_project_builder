 @pytest.fixture                                                
                                                                
 def temp_db_path():                                            
                                                                
     """Create a temporary database file for testing."""        
                                                                
     with tempfile.NamedTemporaryFile(suffix='.db',             
 delete=False) as f:                                            
                                                                
         db_path = f.name                                       
                                                                
     yield db_path                                              
                                                                
     # Clean up the temporary file                              
                                                                
