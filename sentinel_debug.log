 +import sqlite3                                                
 +from dataclasses import dataclass                             
 +from typing import List, Optional                             
 +                                                              
 +@dataclass                                                    
 +class Project:                                                
 +    id: int                                                   
 +    github_url: str                                           
 +    access_token: str                                         
 +                                                              
 +class DatabaseError(Exception):                               
 +    """Custom exception for database-related errors."""       
 +    pass                                                      
 +                                                              
 +def init_database(db_path: str) -> None:                      
 +    """                                                       
 +    Initialize SQLite database with projects table.           
 +                                                              
 +    Args:                                                     
 +        db_path: Path to the SQLite database file             
 +                                                              
 +    Raises:                                                   
 +        DatabaseError: If database initialization fails       
 +    """                                                       
 +    try:                                                      
 +        with sqlite3.connect(db_path) as conn:                
 +            cursor = conn.cursor()                            
 +            cursor.execute("""                                
 +                CREATE TABLE IF NOT EXISTS projects (         
 +                    id INTEGER PRIMARY KEY AUTOINCREMENT,     
 +                    github_url TEXT NOT NULL,                 
 +                    access_token TEXT NOT NULL                
 +                )                                             
 +            """)                                              
 +            conn.commit()                                     
 +    except sqlite3.Error as e:                                
 +        raise DatabaseError(f"Failed to initialize database:  
 {str(e)}")                                                     
 +                                                              
 +def get_project_by_id(db_path: str, project_id: int) ->       
 Optional[Project]:                                             
 +    """                                                       
 +    Retrieve a project by its ID.                             
 +                                                              
 +    Args:                                                     
 +        db_path: Path to the SQLite database file             
 +        project_id: ID of the project to retrieve             
 +                                                              
 +    Returns:                                                  
 +        Project object if found, None otherwise               
 +                                                              
 +    Raises:                                                   
 +        DatabaseError: If database operation fails            
 +    """                                                       
 +    try:                                                      
 +        with sqlite3.connect(db_path) as conn:                
 +            conn.row_factory = sqlite3.Row                    
 +            cursor = conn.cursor()                            
 +            cursor.execute("SELECT * FROM projects WHERE id = 
 ?", (project_id,))                                             
 +            row = cursor.fetchone()                           
 +                                                              
 +            if row is None:                                   
 +                return None                                   
 +                                                              
 +            return Project(                                   
 +                id=row['id'],                                 
 +                github_url=row['github_url'],                 
 +                access_token=row['access_token']              
 +            )                                                 
 +    except sqlite3.Error as e:                                
 +        raise DatabaseError(f"Failed to retrieve project:     
 {str(e)}")                                                     
 +                                                              
 +def add_project(db_path: str, github_url: str, access_token:  
 str) -> int:                                                   
 +    """                                                       
 +    Add a new project to the database.                        
 +                                                              
 +    Args:                                                     
 +        db_path: Path to the SQLite database file             
 +        github_url: GitHub repository URL                     
 +        access_token: Access token for the repository         
 +                                                              
 +    Returns:                                                  
 +        ID of the newly created project                       
 +                                                              
 +    Raises:                                                   
 +        DatabaseError: If database operation fails            
 +    """                                                       
 +    try:                                                      
 +        with sqlite3.connect(db_path) as conn:                
 +            cursor = conn.cursor()                            
 +            cursor.execute(                                   
 +                "INSERT INTO projects (github_url,            
 access_token) VALUES (?, ?)",                                  
 +                (github_url, access_token)                    
 +            )                                                 
 +            conn.commit()                                     
 +            return cursor.lastrowid                           
 +    except sqlite3.Error as e:                                
 +        raise DatabaseError(f"Failed to add project:          
 {str(e)}")                                                     
 +                                                              
 +def list_projects(db_path: str) -> List[Project]:             
 +    """                                                       
 +    Retrieve all projects from the database.                  
 +                                                              
 +    Args:                                                     
 +        db_path: Path to the SQLite database file             
 +                                                              
 +    Returns:                                                  
 +        List of Project objects                               
 +                                                              
 +    Raises:                                                   
 +        DatabaseError: If database operation fails            
 +    """                                                       
 +    try:                                                      
 +        with sqlite3.connect(db_path) as conn:                
 +            conn.row_factory = sqlite3.Row                    
 +            cursor = conn.cursor()                            
 +            cursor.execute("SELECT * FROM projects")          
 +            rows = cursor.fetchall()                          
 +                                                              
 +            return [                                          
 +                Project(                                      
 +                    id=row['id'],                             
 +                    github_url=row['github_url'],             
 +                    access_token=row['access_token']          
 +                )                                             
 +                for row in rows                               
 +            ]                                                 
 +    except sqlite3.Error as e:                                
 +        raise DatabaseError(f"Failed to list projects:        
 {str(e)}")                                                     
                                                                

