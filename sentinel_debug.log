 def test_init_database_creates_table(temp_db_path):            
                                                                
     """Test that database initialization creates the projects  
 table with correct schema."""                                  
                                                                
     init_database(temp_db_path)                                
                                                                
                                                                
                                                                
     # Verify table exists and has correct structure            
                                                                
     with sqlite3.connect(temp_db_path) as conn:                
                                                                
         conn.row_factory = sqlite3.Row                         
                                                                
         cursor = conn.cursor()                                 
                                                                
         cursor.execute("SELECT name FROM sqlite_master WHERE   
 type='table' AND name='projects'")                             
                                                                
         table_exists = cursor.fetchone()                       
                                                                
         assert table_exists is not None                        
                                                                
                                                                
                                                                
         # Check table schema                                   
                                                                
         cursor.execute("PRAGMA table_info(projects)")          
                                                                
         columns = cursor.fetchall()                            
                                                                
                                                                
                                                                
         # Should have 3 columns: id, github_url, access_token  
                                                                
         assert len(columns) == 3                               
                                                                
                                                                
                                                                
         # Check column names and types                         
                                                                
         column_names = [col['name'] for col in columns]        
                                                                
         assert 'id' in column_names                            
                                                                
         assert 'github_url' in column_names                    
                                                                
         assert 'access_token' in column_names                  
                                                                
                                                                
                                                                
         # Check that id is primary key and autoincrement       
                                                                
         for col in columns:                                    
                                                                
             if col['name'] == 'id':                            
                                                                
                 assert col['pk'] == 1  # Primary key           
                                                                
                 break                                          
                                                                
                                                                
                                                                
 def test_init_database_idempotent(temp_db_path):               
                                                                
     """Test that database initialization is idempotent."""     
                                                                
     # Initialize twice                                         
                                                                
     init_database(temp_db_path)                                
                                                                
     init_database(temp_db_path)                                
                                                                
                                                                
                                                                
     # Should not raise any errors and table should exist       
                                                                
     with sqlite3.connect(temp_db_path) as conn:                
                                                                
         conn.row_factory = sqlite3.Row                         
                                                                
         cursor = conn.cursor()                                 
                                                                
         cursor.execute("SELECT name FROM sqlite_master WHERE   
 type='table' AND name='projects'")                             
                                                                
         table_exists = cursor.fetchone()                       
                                                                
         assert table_exists is not None                        
                                                                
                                                                
                                                                
 def test_add_and_get_project(temp_db_path):                    
                                                                
